# 默认使用 PostgreSQL（与 docker-compose.yml 一致）。勿再使用 SQLite 作为默认库。
# 复制为 backend/.env 或导出到环境变量后启动 uvicorn。

# 覆盖 test / prod 两套默认 URL（本地 docker-compose 默认库名为 aisoul）
# AISOU_DB_MODE=test
AISOU_DB_URL_TEST=postgresql+psycopg://aisoul:aisoul@127.0.0.1:5432/aisoul
AISOU_DB_URL_PROD=postgresql+psycopg://aisoul:aisoul@127.0.0.1:5432/aisoul

# 或一条 URL 覆盖以上逻辑：
# AISOU_DATABASE_URL=postgresql+psycopg://aisoul:aisoul@127.0.0.1:5432/aisoul
